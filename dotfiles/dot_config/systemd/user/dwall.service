[Unit]
Description=Dynamic Wallpaper Changer (dwall)
After=graphical-session.target

[Service]
Type=simple
Environment=DISPLAY=:0
Environment=DESKTOP_SESSION=Openbox
Environment=DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus
ExecStart=/usr/bin/dwall -s firewatch

[Install]
WantedBy=default.target

#!/bin/sh
# cx - change executability
#
# Toggle a file between executable and non-executable.
#
# Usage: cx <file1> [file2 ...]
#

for file ; do
    if [ -f "$file" ] ; then
        if [ -x "$file" ] ; then
            chmod -x "$file"
        else
            chmod +x "$file"
        fi
    else
        >&2 printf 'Error: %s does not exist.\n' "$file"
    fi
done
